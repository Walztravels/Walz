{
  "alias": ["walztravels.com", "www.walztravels.com", "walztravels.us", "www.walztravels.us"],
  "functions": {
    "app/api/public/group/[param]/lock/route.ts": { "maxDuration": 120 },
    "app/api/admin/visa/analyse/route.ts":         { "maxDuration": 300 },
    "app/api/admin/payroll/transfer/route.ts":     { "maxDuration": 60  },
    "app/api/admin/payroll/auto-run/route.ts":     { "maxDuration": 60  }
  },
  "crons": [
    {
      "path": "/api/cron/payroll",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/visa-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/routing-escalation",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/check-flight-prices",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/admin/payroll/auto-run",
      "schedule": "0 9 28 * *"
    }
  ]
}
