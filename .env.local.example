# ============================================================
# Walz Travels — Environment Variables
# Copy this file to .env.local and fill in your real values
# NEVER commit .env.local to version control
# ============================================================

# ── Application ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (PostgreSQL via Prisma) ─────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/walz_travels?schema=public

# ── NextAuth.js ───────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32

# ── Google OAuth ──────────────────────────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Sabre GDS API ─────────────────────────────────────────────
# Environment: 'cert' for sandbox, 'prod' for production
SABRE_ENV=cert
# REST API credentials from developer.sabre.com
# client_id format: V1:EPR:IPCC:AA  (e.g. V1:177382:RR9K:AA)
SABRE_CLIENT_ID=your-sabre-client-id
SABRE_CLIENT_SECRET=your-sabre-client-secret
# Walz Travels IPCC / PCC
SABRE_PCC=RR9K
# Additional Sabre identifiers (for reference / audit)
SABRE_IPCC=RR9K
SABRE_SC_CODE=RJ3K
SABRE_HOST_PCC=RJ3K
SABRE_EPR_1=177382
SABRE_EPR_2=177383

# ── Stripe Payments ───────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Get from: https://dashboard.stripe.com/webhooks (after creating a webhook endpoint)
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Resend Email ──────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# ── Redis ─────────────────────────────────────────────────────
# Local development: redis://localhost:6379
# Production: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# ── Google Flights (SerpApi) ──────────────────────────────────
# Get from: https://serpapi.com/manage-api-key
SERPAPI_KEY=your-serpapi-key

# ── Duffel (Flights, Cars, Stays) ─────────────────────────────
# Get from: https://app.duffel.com/join (Settings → Access tokens)
# Use a test token (duffel_test_...) for development
DUFFEL_ACCESS_TOKEN=duffel_test_your-access-token-here

# ── Skyscanner (via RapidAPI) ──────────────────────────────────
# Subscribe at: https://rapidapi.com/skyscanner/api/skyscanner50
RAPIDAPI_KEY=your-rapidapi-key

# ── Walz Travels Business ─────────────────────────────────────
WALZ_FROM_EMAIL=bookings@walztravels.com
WALZ_WHATSAPP_1=+447398753797
WALZ_WHATSAPP_2=+447398753797
WALZ_EMERGENCY_PHONE=+19843880110
WALZ_OFFICE_ADDRESS=1 Commercial Street, London, E1 6RF
