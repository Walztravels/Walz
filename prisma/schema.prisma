  departure_date    DateTime? @db.Timestamptz(6)
  return_date       DateTime? @db.Timestamptz(6)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([slug])
  @@index([is_active])
  @@index([is_featured])
  @@index([display_order])
}

/// Raw site_media table — managed outside Prisma ORM
model site_media {
