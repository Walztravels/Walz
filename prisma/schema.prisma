// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// NextAuth Required Models
// ===========================

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  stripeCustomerId     String?   @unique
  password                  String?
  passwordResetToken        String?
  passwordResetExpires      DateTime?
  verificationToken         String?
  verificationTokenExpires  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  bookings            Booking[]
  visaApplications    VisaApplication[]
  tourEnquiries       TourEnquiry[]
  portalApplications  PortalApplication[]
  portalDocuments     PortalDocument[]
  portalPayments      PortalPayment[]
  referralCode        ReferralCode?
  purchasedVouchers   Voucher[]  @relation("VoucherPurchased")
  receivedVouchers    Voucher[]  @relation("VoucherReceived")
  passportVault       PassportVault?
  applicationDrafts   ApplicationDraft[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================
// Travel Booking Models
// ===========================

enum BookingType {
  FLIGHT
  HOTEL
  PACKAGE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

model Booking {
  id               String        @id @default(cuid())
  userId           String?
  bookingReference String        @unique
  pnr              String?
  type             BookingType
  status           BookingStatus @default(PENDING)
  paymentStatus    PaymentStatus @default(PENDING)

  // Pricing
  totalAmount      Float
  currency         String        @default("GBP")

  // Stripe
  stripePaymentIntentId String?
  stripeClientSecret    String?

  // Contact details
  contactEmail  String
  contactPhone  String?

  // Flight details (JSON for flexibility)
  flightDetails Json?

  // Hotel details (JSON)
  hotelDetails Json?

  // Passenger details (JSON array)
  passengers Json?

  // Addons
  addons Json?

  // Metadata
  notes     String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([bookingReference])
  @@index([pnr])
  @@index([stripePaymentIntentId])
  @@index([status])
  @@index([createdAt])
}

// ===========================
// Visa Applications (Full)
// Statuses (String): draft | received | documents_pending | under_review |
//   ready_to_submit | submitted_to_embassy | decision_pending | approved | refused
// ===========================

model VisaApplication {
  id              String    @id @default(cuid())
  referenceNumber String    @unique
  userId          String?
  destinationIso2 String
  visaType        String    @default("tourist")

  // ── Personal ────────────────────────────────────
  firstName         String?
  middleName        String?
  lastName          String?
  dateOfBirth       DateTime?
  sex               String?
  placeOfBirth      String?
  nationality       String?
  maritalStatus     String?

  // ── Passport ────────────────────────────────────
  passportNumber      String?
  passportType        String?
  passportIssueDate   DateTime?
  passportExpiryDate  DateTime?
  issuingAuthority    String?
  issuingCountry      String?

  // ── Contact ─────────────────────────────────────
  phone        String?
  email        String?
  homeAddress  String?
  homeAddress2 String?
  city         String?
  stateRegion  String?
  country      String?
  postalCode   String?

  // ── Employment ──────────────────────────────────
  employmentStatus String?
  employerName     String?
  jobTitle         String?
  employerAddress  String?
  monthlyIncome    String?

  // ── Travel ──────────────────────────────────────
  arrivalDate          DateTime?
  returnDate           DateTime?
  purposeOfVisit       String?
  accommodationName    String?
  accommodationAddress String?
  portOfEntry          String?

  // ── Visa history ────────────────────────────────
  previousRefusal        Boolean @default(false)
  previousRefusalDetails String?
  previousVisits         Boolean @default(false)
  previousVisitDetails   String?

  // ── Background ──────────────────────────────────
  criminalRecord       Boolean @default(false)
  communicableDisease  Boolean @default(false)
  deportedBefore       Boolean @default(false)

  // ── Country-specific extra fields (JSON) ────────
  countrySpecific Json @default("{}")

  // ── Declaration ─────────────────────────────────
  declarationAccurate  Boolean @default(false)
  declarationAuthorise Boolean @default(false)
  declarationFeePolicy Boolean @default(false)

  // ── Status ──────────────────────────────────────
  status  String @default("draft")
  isDraft Boolean @default(true)

  // ── Admin ───────────────────────────────────────
  assignedTo       String?
  embassyReference String?
  submissionDate   DateTime?
  decisionDate     DateTime?
  decisionNotes    String?   @db.Text
  govtFeeInstructions String? @db.Text

  // ── Payment ─────────────────────────────────────
  serviceFeePaid          Boolean  @default(false)
  serviceFeeAmount        Decimal?
  serviceFeeCurrency      String   @default("USD")
  stripePaymentIntentId   String?
  govtFeePaid             Boolean  @default(false)
  govtFeeAmount           Decimal?

  // ── PDF ─────────────────────────────────────────
  pdfUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes VisaApplicationNote[]

  @@index([userId])
  @@index([status])
  @@index([destinationIso2])
  @@index([referenceNumber])
}

model VisaApplicationNote {
  id            String          @id @default(cuid())
  applicationId String
  authorName    String
  content       String          @db.Text
  createdAt     DateTime        @default(now())

  application VisaApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ===========================
// Tour Enquiries
// ===========================

enum TourEnquiryStatus {
  NEW
  CONTACTED
  QUOTED
  BOOKED
  CANCELLED
}

model TourEnquiry {
  id     String            @id @default(cuid())
  userId String?
  status TourEnquiryStatus @default(NEW)

  // Contact
  firstName String
  lastName  String
  email     String
  phone     String

  // Tour details
  tourName                String
  tourDate                String
  groupSize               Int
  specialRequirements     String? @db.Text
  preferredPickupLocation String?

  // Quote
  quotedPrice Float?
  currency    String  @default("GBP")

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([tourName])
}

// ===========================
// Admin CRM Models
// ===========================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String?
  updatedAt DateTime @updatedAt
}

// ===========================
// Staff & Activity Log
// ===========================

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String?
  whatsapp    String
  service     String   // Visa Processing, Flight Booking, Holiday Package, Group Travel, Corporate Travel, Hotel Only, Other
  destination String?
  travelDate  String?
  details     String?  @db.Text
  source      String   @default("homepage")
  status      String   @default("New") // New, Contacted, Deposit Paid, In Progress, Closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([service])
  @@index([source])
}

model Staff {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  roleTitle    String    // Free-text role name, e.g. "Senior Sales Agent"
  accessLevel  String    // Admin | Manager | Coordinator | Sales
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityLogs ActivityLog[]

  @@index([email])
  @@index([isActive])
  @@index([accessLevel])
}

model ActivityLog {
  id        String   @id @default(cuid())
  staffId   String?
  staffName String?
  action    String
  detail    String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  staff Staff? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([createdAt])
}

model WidgetConfig {
  id      String  @id @default(cuid())
  key     String  @unique
  label   String
  enabled Boolean @default(true)
  order   Int     @default(0)
}

model FeaturedDeal {
  id          String   @id @default(cuid())
  origin      String
  destination String
  price       Float
  currency    String   @default("GBP")
  airline     String?
  imageUrl    String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TourListing {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  highlights  String   @db.Text @default("[]")
  price       Float
  currency    String   @default("GBP")
  duration    String
  location    String
  imageUrl    String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VisaService {
  id             String   @id @default(cuid())
  country        String
  flag           String?
  visaType       String
  processingTime String
  fee            Float
  currency       String   @default("GBP")
  requirements   String   @db.Text @default("[]")
  imageUrl       String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([country, visaType])
}

model SiteImage {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  url       String
  bucket    String   @default("walz-images")
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===========================
// Blog
// ===========================

model BlogPost {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  content          String   @db.Text
  excerpt          String?  @db.Text
  category         String   @default("Travel Tips")
  featuredImageUrl String?
  metaDescription  String?  @db.Text
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
  @@index([createdAt])
}

// ===========================
// Vouchers
// ===========================

model Voucher {
  id                    String    @id @default(cuid())
  code                  String    @unique
  name                  String?

  // Classification
  voucherKind           String    @default("gift")   // 'gift' | 'credit'
  serviceType           String    @default("all")    // 'visa' | 'flight' | 'tour' | 'all'
  discountType          String    @default("fixed")  // 'fixed' | 'percentage' | 'free'

  // Value
  amount                Float
  currency              String    @default("GBP")
  remainingAmount       Float

  // Tour specific
  tourName              String?

  // Uses
  maxUses               Int       @default(1)
  usedCount             Int       @default(0)

  // Status
  status                String    @default("ACTIVE") // ACTIVE | PURCHASED | SENT | REDEEMED | EXPIRED | CANCELLED
  active                Boolean   @default(true)

  // Owner / purchaser — links to portal account
  purchasedByUserId     String?
  purchasedByUser       User?     @relation("VoucherPurchased", fields: [purchasedByUserId], references: [id], onDelete: SetNull)
  recipientUserId       String?
  recipientUser         User?     @relation("VoucherReceived",  fields: [recipientUserId],  references: [id], onDelete: SetNull)

  // Sender (gift vouchers purchased by users)
  senderName            String?
  senderEmail           String?

  // Recipient
  recipientName         String?
  recipientEmail        String?
  personalMessage       String?   @db.Text

  // Delivery
  scheduledDeliveryDate DateTime?
  sentAt                DateTime?

  // Redemption
  redeemedAt            DateTime?
  redeemedBookingId     String?

  // Payment (purchased vouchers)
  paymentReference      String?
  paymentGateway        String?
  paidAmount            Float?

  // Validity
  validFrom             DateTime  @default(now())
  expiresAt             DateTime

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([code])
  @@index([status])
  @@index([voucherKind])
  @@index([active])
  @@index([recipientEmail])
  @@index([senderEmail])
  @@index([expiresAt])
  @@index([purchasedByUserId])
  @@index([recipientUserId])
}

// ===========================
// Client Portal Models
// ===========================

enum ApplicationType {
  VISA
  FLIGHT
  HOTEL
  TOUR
  PACKAGE
  OTHER
}

enum ApplicationStage {
  ENQUIRY
  DOCUMENTS_PENDING
  DOCUMENTS_RECEIVED
  PROCESSING
  SUBMITTED
  APPROVED
  REJECTED
  COMPLETED
}

model PortalApplication {
  id          String             @id @default(cuid())
  userId      String
  refNumber   String             @unique
  type        ApplicationType    @default(OTHER)
  stage       ApplicationStage   @default(ENQUIRY)
  title       String
  destination String?
  travelDate  String?
  notes       String?            @db.Text
  adminNotes  String?            @db.Text
  amount      Float?
  currency    String             @default("GBP")
  amountPaid  Float              @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   PortalDocument[]
  payments    PortalPayment[]
  checklist   ChecklistItem[]

  @@index([userId])
  @@index([stage])
  @@index([type])
  @@index([refNumber])
}

model PortalDocument {
  id            String   @id @default(cuid())
  applicationId String
  userId        String
  name          String
  category      String   @default("General")
  fileUrl       String
  fileKey       String
  fileSize      Int?
  mimeType      String?
  status        String   @default("PENDING")
  reviewNote    String?
  uploadedAt    DateTime @default(now())
  reviewedAt    DateTime?

  application   PortalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([userId])
}

model PortalPayment {
  id            String   @id @default(cuid())
  applicationId String
  userId        String
  amount        Float
  currency      String   @default("GBP")
  description   String
  status        String   @default("PENDING")
  method        String?
  reference     String?
  receiptUrl    String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  application   PortalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([userId])
}

model ChecklistItem {
  id            String    @id @default(cuid())
  applicationId String
  label         String
  description   String?
  required      Boolean   @default(true)
  completedAt   DateTime?
  completedBy   String?
  order         Int       @default(0)

  application   PortalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  uses      Int      @default(0)
  credits   Float    @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}

// ===========================
// Visa Intelligence Hub
// ===========================

model VisaRule {
  passportIso2     String
  destinationIso2  String
  ruleType         String   // visa_required | visa_free | evisa | visa_on_arrival | eta
  maxDays          Int?
  notes            String?
  updatedAt        DateTime @updatedAt

  @@id([passportIso2, destinationIso2])
  @@index([passportIso2])
  @@index([destinationIso2])
}

model CountryPortal {
  destinationIso2   String   @id
  countryName       String
  flagEmoji         String?
  region            String?
  portalUrl         String?
  embassyLocatorUrl String?
  walzFeeUsd        Float    @default(0)
  walzFeeNgn        Float    @default(0)
  govtFeeUsd        Float    @default(0)
  govtFeeAmount     Float    @default(0)
  govtFeeCurrency   String   @default("USD")
  processingDaysMin Int      @default(1)
  processingDaysMax Int      @default(30)
  maxStayDays       Int      @default(30)
  validityDays      Int      @default(90)
  singleOrMultiple  String   @default("single")
  requiredDocuments String[]
  healthRequirements Json    @default("{}")
  jadeTips          String?
  commonRefusals    String[]
  advisoryLevel     Int      @default(1)
  updatedAt         DateTime @updatedAt

  @@index([region])
  @@index([advisoryLevel])
}

model PassportVault {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  givenNames             String?
  surname                String?
  sex                    String?
  dateOfBirth            DateTime?
  placeOfBirth           String?
  nationality            String?
  passportIso2           String?
  dualNationality        String?
  passportNumber         String?
  passportType           String    @default("ordinary")
  issueDate              DateTime?
  expiryDate             DateTime?
  issuingAuthority       String?
  employmentStatus       String?
  employerName           String?
  jobTitle               String?
  incomeRange            String?
  phone                  String?
  homeAddress            String?
  city                   String?
  stateRegion            String?
  country                String?
  postalCode             String?
  criminalRecord         Boolean   @default(false)
  priorVisaDenial        Boolean   @default(false)
  priorVisaDenialDetails String?
  travelHistory          Json      @default("[]")
  emergencyContactName   String?
  emergencyContactPhone  String?
  isSetupComplete        Boolean   @default(false)
  updatedAt              DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApplicationDraft {
  id                String   @id @default(cuid())
  userId            String
  destinationIso2   String?
  serviceType       String?
  draftData         Json     @default("{}")
  status            String   @default("draft")
  walzApplicationId String?
  submittedToPortal Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model TravelAdvisory {
  destinationIso2 String   @id
  advisoryLevel   Int      @default(1)
  advisoryText    String?
  message         String?
  sourceUrl       String?
  cachedAt        DateTime @default(now())
}

model VisaFreeCountry {
  id               String   @id @default(cuid())
  passportCountry  String
  destinationIso2  String
  destinationName  String?
  stayDays         Int?
  conditions       String?
  entryRequirements String[]
  notes            String?

  @@index([passportCountry])
  @@index([destinationIso2])
}

model DocumentGuide {
  id              String   @id @default(cuid())
  visaType        String
  destinationIso2 String?
  documentName    String
  whatItIs        String?
  whyNeeded       String?
  whatItMustShow  Json     @default("[]")
  commonMistakes  Json     @default("[]")
  jadeTip         String?
  updatedAt       DateTime @updatedAt

  @@index([destinationIso2])
  @@index([visaType])
}
