// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===========================
// NextAuth Required Models
// ===========================

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  stripeCustomerId       String?   @unique
  stripePaymentMethodId  String?
  password                  String?
  passwordResetToken        String?
  passwordResetExpires      DateTime?
  verificationToken         String?
  verificationTokenExpires  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  bookings            Booking[]
  visaApplications    VisaApplication[]
  tourEnquiries       TourEnquiry[]
  portalApplications  PortalApplication[]
  portalDocuments     PortalDocument[]
  portalPayments      PortalPayment[]
  referralCode        ReferralCode?
  purchasedVouchers   Voucher[]  @relation("VoucherPurchased")
  receivedVouchers    Voucher[]  @relation("VoucherReceived")
  passportVault       PassportVault?
  applicationDrafts   ApplicationDraft[]
  trips               Trip[]
  tripCollaborations  TripCollaborator[]
  savedItineraries    SavedItinerary[]
  esimOrders          EsimOrder[]
  financialDNA        ClientFinancialDNA?
  riskScore           ClientRiskScore?
  lifecyclePrediction ClientLifecyclePrediction?
  groupSessionsCreated GroupSession[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===========================
// Travel Booking Models
// ===========================

enum BookingType {
  FLIGHT
  HOTEL
  PACKAGE
  ACTIVITY
  TRANSFER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

model Booking {
  id               String        @id @default(cuid())
  userId           String?
  bookingReference String        @unique
  pnr              String?
  type             BookingType
  status           BookingStatus @default(PENDING)
  paymentStatus    PaymentStatus @default(PENDING)

  // Pricing
  totalAmount      Float
  currency         String        @default("GBP")

  // Stripe
  stripePaymentIntentId String?
  stripeClientSecret    String?

  // Contact details
  contactEmail  String
  contactPhone  String?

  // Flight details (JSON for flexibility)
  flightDetails Json?

  // Hotel details (JSON)
  hotelDetails Json?

  // Passenger details (JSON array)
  passengers Json?

  // Addons
  addons Json?

  // Metadata
  notes            String? @db.Text
  createdByStaffId String?
  branch           String  @default("nigeria")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  tickets TicketRecord[]

  @@index([userId])
  @@index([bookingReference])
  @@index([pnr])
  @@index([stripePaymentIntentId])
  @@index([status])
  @@index([createdAt])
}

// ===========================
// Visa Applications (Full)
// Statuses (String): draft | received | documents_pending | under_review |
//   ready_to_submit | submitted_to_embassy | decision_pending | approved | refused
// ===========================

model VisaApplication {
  id              String    @id @default(cuid())
  referenceNumber String    @unique
  userId          String?
  destinationIso2 String
  visaType        String    @default("tourist")

  // ── Personal ────────────────────────────────────
  firstName         String?
  middleName        String?
  lastName          String?
  dateOfBirth       DateTime?
  sex               String?
  placeOfBirth      String?
  nationality       String?
  maritalStatus     String?

  // ── Passport ────────────────────────────────────
  passportNumber      String?
  passportType        String?
  passportIssueDate   DateTime?
  passportExpiryDate  DateTime?
  issuingAuthority    String?
  issuingCountry      String?

  // ── Contact ─────────────────────────────────────
  phone        String?
  email        String?
  homeAddress  String?
  homeAddress2 String?
  city         String?
  stateRegion  String?
  country      String?
  postalCode   String?

  // ── Employment ──────────────────────────────────
  employmentStatus String?
  employerName     String?
  jobTitle         String?
  employerAddress  String?
  monthlyIncome    String?

  // ── Travel ──────────────────────────────────────
  arrivalDate          DateTime?
  returnDate           DateTime?
  purposeOfVisit       String?
  accommodationName    String?
  accommodationAddress String?
  portOfEntry          String?

  // ── Visa history ────────────────────────────────
  previousRefusal        Boolean @default(false)
  previousRefusalDetails String?
  previousVisits         Boolean @default(false)
  previousVisitDetails   String?

  // ── Background ──────────────────────────────────
  criminalRecord       Boolean @default(false)
  communicableDisease  Boolean @default(false)
  deportedBefore       Boolean @default(false)

  // ── Country-specific extra fields (JSON) ────────
  countrySpecific Json @default("{}")

  // ── Declaration ─────────────────────────────────
  declarationAccurate  Boolean @default(false)
  declarationAuthorise Boolean @default(false)
  declarationFeePolicy Boolean @default(false)

  // ── Client portal link ──────────────────────────
  clientAccountId String? @db.Uuid
  clientAccount   ClientAccount? @relation(fields: [clientAccountId], references: [id], onDelete: SetNull)

  // ── Status ──────────────────────────────────────
  status        String  @default("draft")
  statusMessage String?
  timeline      Json    @default("[]")
  isDraft       Boolean @default(true)
  initiatedBy   String  @default("client") // "admin" | "client"

  // ── Admin ───────────────────────────────────────
  assignedTo        String?
  assignedOfficerId String?
  branch            String  @default("nigeria")
  embassyReference  String?
  submissionDate   DateTime?
  decisionDate     DateTime?
  decisionNotes    String?   @db.Text
  govtFeeInstructions String? @db.Text

  // ── Payment ─────────────────────────────────────
  serviceFeePaid          Boolean  @default(false)
  serviceFeeAmount        Decimal?
  serviceFeeCurrency      String   @default("USD")
  stripePaymentIntentId   String?
  govtFeePaid             Boolean  @default(false)
  govtFeeAmount           Decimal?

  // ── PDF ─────────────────────────────────────────
  pdfUrl String?

  // ── Form tracking ────────────────────────────────
  openedAt  DateTime?
  startedAt DateTime?
  viewCount Int       @default(0)

  // ── Appointment ──────────────────────────────────
  appointmentDate     DateTime?
  appointmentNotes    String?
  appointmentLocation String?
  lastEmailSentAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes  VisaApplicationNote[]
  tokens VisaApplicationToken[]

  @@index([userId])
  @@index([status])
  @@index([destinationIso2])
  @@index([referenceNumber])
}

model VisaApplicationNote {
  id            String          @id @default(cuid())
  applicationId String
  authorName    String
  content       String          @db.Text
  createdAt     DateTime        @default(now())

  application VisaApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model VisaApplicationToken {
  id            String          @id @default(cuid())
  token         String          @unique @default(cuid())
  applicationId String
  clientEmail   String
  clientName    String
  used          Boolean         @default(false)
  expiresAt     DateTime
  createdAt     DateTime        @default(now())

  application VisaApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([applicationId])
}

// ===========================
// Tour Enquiries
// ===========================

enum TourEnquiryStatus {
  NEW
  CONTACTED
  QUOTED
  BOOKED
  CANCELLED
}

model TourEnquiry {
  id     String            @id @default(cuid())
  userId String?
  status TourEnquiryStatus @default(NEW)

  // Contact
  firstName String
  lastName  String
  email     String
  phone     String

  // Tour details
  tourName                String
  tourDate                String
  groupSize               Int
  specialRequirements     String? @db.Text
  preferredPickupLocation String?

  // Quote
  quotedPrice Float?
  currency    String  @default("GBP")

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([tourName])
}

// ===========================
// Admin CRM Models
// ===========================

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===========================
// Staff & Activity Log
// ===========================

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String?
  whatsapp    String?
  service     String   @default("Other") // Visa Processing, Flight Booking, Holiday Package, Group Travel, Corporate Travel, Hotel Only, Other
  destination String?
  travelDate  String?
  details     String?  @db.Text
  source      String   @default("homepage") // homepage | facebook | instagram | whatsapp | referral
  status      String   @default("New")      // New, Contacted, Deposit Paid, In Progress, Closed
  // ── Social / messaging ─────────────────────────────────────────────────
  sourceId          String?   // FB/IG PSID or unique sender id
  instagramUsername String?
  conversation      Json      @default("[]")  // [{role, message, timestamp}]
  lastMessage       String?   @db.Text
  lastMessageAt     DateTime?
  isRead            Boolean   @default(true)
  jadeActive        Boolean   @default(true)
  jadeSilencedAt    DateTime?  // set when human agent sends — Jade stays silent
  jadeResumedAt     DateTime?  // set when 30-min window expires and Jade auto-resumes
  assignedTo        String?   // legacy string assignment
  assignedToId      String?   // FK to Staff (row-level security)
  branch            String    @default("nigeria")
  platform          String?   // Facebook | Instagram | WhatsApp | Website
  // ──────────────────────────────────────────────────────────────────────
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([service])
  @@index([source])
  @@index([sourceId])
  @@index([isRead])
  @@index([assignedToId])
  @@index([branch])
}

// ===========================
// Notifications (admin alerts)
// ===========================

model Notification {
  id        String   @id @default(cuid())
  type      String   // new_facebook_message | new_instagram_message | new_lead | etc.
  title     String
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([read])
  @@index([type])
  @@index([createdAt])
}

model Staff {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  roleTitle    String    // Free-text job title e.g. "Senior Sales Agent"
  accessLevel  String    @default("sales_rep") // legacy compat — derived from role
  role         String    @default("sales_rep")
  // departments: general | visa | flights | tours | hotels | sales | accounts | support
  department   String    @default("general")
  // branches: nigeria | uk | canada | ghana | uae | remote
  branch       String    @default("nigeria")
  managerId    String?   // who this staff member reports to
  permissions  Json      @default("{}")         // per-staff overrides (empty = use role defaults)
  portalAccess Boolean   @default(false)        // can also log into client portal at /portal
  country      String?
  whatsapp     String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityLogs ActivityLog[]
  manager      Staff?    @relation("StaffManager", fields: [managerId], references: [id])
  reports      Staff[]   @relation("StaffManager")

  @@index([email])
  @@index([isActive])
  @@index([accessLevel])
  @@index([role])
  @@index([branch])
  @@index([department])
}

model ActivityLog {
  id          String   @id @default(cuid())
  staffId     String?
  staffName   String?
  staffRole   String?
  staffBranch String?
  action      String
  module      String?  // bookings | visa | clients | staff | settings | content | approvals
  entityId    String?
  entityType  String?
  detail      String?  @db.Text
  ipAddress   String?
  userAgent   String?
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  staff Staff? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([module])
  @@index([createdAt])
}

model WidgetConfig {
  id      String  @id @default(cuid())
  key     String  @unique
  label   String
  enabled Boolean @default(true)
  order   Int     @default(0)
}

model FeaturedDeal {
  id          String   @id @default(cuid())
  origin      String
  destination String
  fromLabel   String   @default("")
  toLabel     String   @default("")
  tripType    String   @default("ROUNDTRIP")
  departDate  String?
  returnDate  String?
  price       Float
  currency    String   @default("GBP")
  airline     String?
  caption     String?
  badge       String?
  photos      String   @default("[]")
  imageUrl    String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeaturedHotel {
  id            String   @id @default(cuid())
  name          String
  location      String
  searchQuery   String
  propertyType  String   @default("Hotel")
  rating        Float?
  reviewCount   Int?
  reviewLabel   String?
  priceFrom     Float?
  priceOriginal Float?
  currency      String   @default("USD")
  caption       String?
  badge         String?
  photos        String   @default("[]")
  bookingUrl    String?
  active        Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TourListing {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @db.Text
  highlights  String   @db.Text @default("[]")
  price       Float
  currency    String   @default("GBP")
  duration    String
  location    String
  imageUrl    String?
  photos      String[] // ordered array of photo URLs (index 0 = hero/cover)
  active      Boolean  @default(true)
  order       Int      @default(0)
  type        String   @default("tour") // "tour" | "package"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VisaService {
  id             String   @id @default(cuid())
  country        String
  flag           String?
  visaType       String
  processingTime String
  fee            Float
  currency       String   @default("GBP")
  requirements   String   @db.Text @default("[]")
  imageUrl       String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([country, visaType])
}

model SiteImage {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  url       String
  bucket    String   @default("walz-images")
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===========================
// Blog
// ===========================

model BlogPost {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  content          String   @db.Text
  excerpt          String?  @db.Text
  category         String   @default("Travel Tips")
  featuredImageUrl String?
  metaDescription  String?  @db.Text
  published        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
  @@index([createdAt])
}

// ===========================
// Vouchers
// ===========================

model Voucher {
  id                    String    @id @default(cuid())
  code                  String    @unique
  name                  String?

  // Classification
  voucherKind           String    @default("gift")   // 'gift' | 'credit'
  serviceType           String    @default("all")    // 'visa' | 'flight' | 'tour' | 'all'
  discountType          String    @default("fixed")  // 'fixed' | 'percentage' | 'free'

  // Value
  amount                Float
  currency              String    @default("GBP")
  remainingAmount       Float

  // Tour specific
  tourName              String?

  // Uses
  maxUses               Int       @default(1)
  usedCount             Int       @default(0)

  // Status
  status                String    @default("ACTIVE") // ACTIVE | PURCHASED | SENT | REDEEMED | EXPIRED | CANCELLED
  active                Boolean   @default(true)

  // Owner / purchaser — links to portal account
  purchasedByUserId     String?
  purchasedByUser       User?     @relation("VoucherPurchased", fields: [purchasedByUserId], references: [id], onDelete: SetNull)
  recipientUserId       String?
  recipientUser         User?     @relation("VoucherReceived",  fields: [recipientUserId],  references: [id], onDelete: SetNull)

  // Sender (gift vouchers purchased by users)
  senderName            String?
  senderEmail           String?

  // Recipient
  recipientName         String?
  recipientEmail        String?
  personalMessage       String?   @db.Text

  // Delivery
  scheduledDeliveryDate DateTime?
  sentAt                DateTime?

  // Redemption
  redeemedAt            DateTime?
  redeemedBookingId     String?

  // Payment (purchased vouchers)
  paymentReference      String?
  paymentGateway        String?
  paidAmount            Float?

  // Validity
  validFrom             DateTime  @default(now())
  expiresAt             DateTime

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([code])
  @@index([status])
  @@index([voucherKind])
  @@index([active])
  @@index([recipientEmail])
  @@index([senderEmail])
  @@index([expiresAt])
  @@index([purchasedByUserId])
  @@index([recipientUserId])
}

// ===========================
// Client Portal Models
// ===========================

enum ApplicationType {
  VISA
  FLIGHT
  HOTEL
  TOUR
  PACKAGE
  OTHER
}

enum ApplicationStage {
  ENQUIRY
  DOCUMENTS_PENDING
  DOCUMENTS_RECEIVED
  PROCESSING
  SUBMITTED
  AWAITING_DECISION
  APPROVED
  REJECTED
  COMPLETED
}

model PortalApplication {
  id          String             @id @default(cuid())
  userId      String
  refNumber   String             @unique
  type        ApplicationType    @default(OTHER)
  stage       ApplicationStage   @default(ENQUIRY)
  title       String
  destination String?
  travelDate  String?
  notes       String?            @db.Text
  adminNotes  String?            @db.Text
  amount      Float?
  currency    String             @default("GBP")
  amountPaid  Float              @default(0)

  // Admin-editable fee breakdown
  walzFee      Float?
  walzCurrency String?           @default("GBP")
  govFee       Float?
  govCurrency  String?           @default("GBP")
  govFeeNote   String?           @default("paid later")

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Progress tracker
  trackingToken String?                 @unique @default(cuid())
  updates       VisaApplicationUpdate[]

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   PortalDocument[]
  payments    PortalPayment[]
  checklist   ChecklistItem[]

  @@index([userId])
  @@index([stage])
  @@index([type])
  @@index([refNumber])
}

model VisaApplicationUpdate {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  applicationId String
  application   PortalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  adminName     String   @default("Walz Travels Team")
  type          String   @default("STATUS_UPDATE")
  // STATUS_UPDATE | NOTE | DOCUMENT | APPOINTMENT | DECISION

  newStatus     String?
  title         String
  message       String   @db.Text

  documentName  String?
  documentUrl   String?
  documentType  String?
  // EMBASSY_FORM | APPOINTMENT_LETTER | VISA_COPY | CHECKLIST | OTHER

  emailSent     Boolean  @default(false)
  emailSentAt   DateTime?
  isClientVisible Boolean @default(true)

  @@index([applicationId])
}

model PortalDocument {
  id            String   @id @default(cuid())
  applicationId String
  userId        String
  name          String
  category      String   @default("General")
  fileUrl       String
  fileKey       String
  fileSize      Int?
  mimeType      String?
  status        String   @default("PENDING")
  reviewNote    String?
  uploadedAt    DateTime @default(now())
  reviewedAt    DateTime?

  application   PortalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([userId])
}

model PortalPayment {
  id            String   @id @default(cuid())
  applicationId String
  userId        String
  amount        Float
  currency      String   @default("GBP")
  description   String
  status        String   @default("PENDING")
  method        String?
  reference     String?
  receiptUrl    String?
  paidAt        DateTime?
  createdAt     DateTime @default(now())

  application   PortalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([userId])
}

model ChecklistItem {
  id            String    @id @default(cuid())
  applicationId String
  label         String
  description   String?
  required      Boolean   @default(true)
  completedAt   DateTime?
  completedBy   String?
  order         Int       @default(0)

  application   PortalApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  uses      Int      @default(0)
  credits   Float    @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
}

// ===========================
// Visa Intelligence Hub
// ===========================

model VisaRule {
  passportIso2     String
  destinationIso2  String
  ruleType         String   // visa_required | visa_free | evisa | visa_on_arrival | eta
  maxDays          Int?
  notes            String?
  updatedAt        DateTime @updatedAt

  @@id([passportIso2, destinationIso2])
  @@index([passportIso2])
  @@index([destinationIso2])
}

model CountryPortal {
  destinationIso2   String   @id
  countryName       String
  flagEmoji         String?
  region            String?
  portalUrl         String?
  embassyLocatorUrl String?
  walzFeeUsd        Float    @default(0)
  walzFeeNgn        Float    @default(0)
  govtFeeUsd        Float    @default(0)
  govtFeeAmount     Float    @default(0)
  govtFeeCurrency   String   @default("USD")
  processingDaysMin Int      @default(1)
  processingDaysMax Int      @default(30)
  maxStayDays       Int      @default(30)
  validityDays      Int      @default(90)
  singleOrMultiple  String   @default("single")
  requiredDocuments String[]
  healthRequirements Json    @default("{}")
  jadeTips          String?
  commonRefusals    String[]
  advisoryLevel     Int      @default(1)
  updatedAt         DateTime @updatedAt

  @@index([region])
  @@index([advisoryLevel])
}

model PassportVault {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  givenNames             String?
  surname                String?
  sex                    String?
  dateOfBirth            DateTime?
  placeOfBirth           String?
  nationality            String?
  passportIso2           String?
  dualNationality        String?
  passportNumber         String?
  passportType           String    @default("ordinary")
