  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  slug              String    @unique
  destination       String?
  country_iso2      String?
  tagline           String?
  description       String?
  package_type      String?
  departure_city    String?
  currency          String?   @default("GBP")
  meals             String?
  seo_title         String?
  seo_description   String?
  price_per_person  Decimal   @db.Decimal(10, 2)
  original_price    Decimal?  @db.Decimal(10, 2)
  deposit_amount    Decimal?  @db.Decimal(10, 2)
  duration_days     Int?
  duration_nights   Int?
  total_seats       Int?
  seats_booked      Int?      @default(0)
  hotel_rating      Decimal?  @db.Decimal(3, 1)
  display_order     Int?      @default(0)
  visa_included     Boolean?  @default(false)
  flight_included   Boolean?  @default(false)
  hotel_included    Boolean?  @default(false)
  is_featured       Boolean?  @default(false)
  is_active         Boolean?  @default(true)
  is_spotlight      Boolean?  @default(false)
  highlights        String[]
  inclusions        String[]
  exclusions        String[]
  images            String[]
