// ===========================
// Jade Planner
// ===========================

enum TripStatus {
  DRAFT
  PLANNING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum TripItemType {
  FLIGHT
  HOTEL
  TOUR
  VISA
  ESIM
  ACTIVITY
  RESTAURANT
  TRANSPORT
  NOTE
  CUSTOM
}

model Trip {
  id          String     @id @default(cuid())
  userId      String
  title       String
  destination String
  description String?    @db.Text
  coverImage  String?
  startDate   DateTime?
  endDate     DateTime?
  status      TripStatus @default(DRAFT)
  isPublic    Boolean    @default(false)
  shareToken  String?    @unique
  budget      Float?
  currency    String     @default("GBP")
  notes       String?    @db.Text
  templateId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  template      TripTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  days          TripDay[]
  items         TripItem[]
  collaborators TripCollaborator[]
  proposals     TripProposal[]
  messages      TripMessage[]
  invoices      Invoice[]

  @@index([userId])
  @@index([status])
  @@index([shareToken])
  @@index([templateId])
}

model TripDay {
  id        String    @id @default(cuid())
  tripId    String
  dayNumber Int
  date      DateTime?
  title     String?
  notes     String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip  Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items TripItem[]

  @@unique([tripId, dayNumber])
  @@index([tripId])
}

model TripItem {
  id          String       @id @default(cuid())
  tripId      String
  dayId       String?
  type        TripItemType @default(CUSTOM)
  title       String
  description String?      @db.Text
  location    String?
  startTime   String?
  endTime     String?
  cost        Float?
  currency    String       @default("GBP")
  imageUrl    String?
  externalUrl String?
  bookingRef  String?
  confirmed   Boolean      @default(false)
  order       Int          @default(0)
  metadata    Json         @default("{}")
  sourceType  String?
  sourceId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  day  TripDay? @relation(fields: [dayId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([dayId])
  @@index([type])
}

model TripCollaborator {
  id          String  @id @default(cuid())
  tripId      String
  userId      String?
  email       String
  role        String  @default("viewer")
  status      String  @default("pending")
  inviteToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tripId])
  @@index([userId])
  @@index([email])
  @@index([inviteToken])
}

model TripProposal {
  id         String    @id @default(cuid())
  tripId     String
  staffId    String?
  staffName  String?
  title      String
  content    String    @db.Text
  itinerary  Json      @default("[]")
  totalCost  Float?
  currency   String    @default("GBP")
  status     String    @default("draft")
  validUntil DateTime?
  pdfUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([staffId])
  @@index([status])
}

model TripTemplate {
  id          String   @id @default(cuid())
  name        String
  destination String
  description String?  @db.Text
  coverImage  String?
  duration    Int
  highlights  String[]
  itinerary   Json     @default("[]")
  category    String   @default("leisure")
  tags        String[]
  active      Boolean  @default(true)
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips Trip[]

  @@index([category])
  @@index([active])
  @@index([destination])
}

model TripMessage {
  id       String @id @default(cuid())
  tripId   String
  role     String
  content  String @db.Text
  metadata Json   @default("{}")

  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([createdAt])
}

model SavedItinerary {
  id          String  @id @default(cuid())
  userId      String
  title       String
  source      String
  itinerary   Json    @default("{}")
  destination String?
  duration    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([source])
}

// ===========================
// JADE CONNECT — eSIM Orders
// ===========================

model EsimOrder {
  id                  String    @id @default(cuid())
  userId              String?
  tripId              String?
  orderRef            String    @unique   // JADE-ESIM-timestamp-random
  transactionId       String?             // same as orderRef — sent to eSIM Access
  esimAccessOrderNo   String?             // returned by eSIM Access
  destination         String
  destinationIso2     String
  packageCode         String
  packageName         String
  durationDays        Int
  dataAmount          Float?              // raw MB value from API
  dataUnit            String?             // 'MB' | 'GB' | 'Unlimited'
  wholesaleCostUsd    Float
  retailPriceUsd      Float
  marginUsd           Float
  currency            String    @default("USD")
  iccid               String?
  qrCodeUrl           String?
  activationCode      String?             // AC code
  smdpAddress         String?             // SM-DP+ address
  lpaString           String?             // LPA:1:smdp:ac combined
  status              String    @default("pending")  // pending | active | cancelled | expired
  stripePaymentId     String?
  emailSent           Boolean   @default(false)
  purchasedAt         DateTime  @default(now())
  activatedAt         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  topups  EsimTopup[]

  @@index([userId])
  @@index([status])
  @@index([destinationIso2])
  @@index([orderRef])
  @@index([iccid])
}

model EsimTopup {
  id          String    @id @default(cuid())
  orderId     String
  userId      String?
  packageCode String
  amount      Float
  currency    String    @default("USD")
  status      String    @default("pending")
  createdAt   DateTime  @default(now())

  order   EsimOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
}

// ===========================
// Tours (bookable tours catalogue)
// ===========================

model Tour {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  location    String
  duration    String
  price       Float
  currency    String   @default("USD")
  description String
  highlights  String?
  photos      String[]
  active      Boolean  @default(true)
  order       Int      @default(0)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

