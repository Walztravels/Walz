# =============================================================================
# Walz Travels — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.walztravels.com

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...     # NEVER expose to the browser

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_ADMIN_SECRET=change-me-to-a-random-64-char-secret

# Fallback env-var super-admin (can also use Staff table instead)
ADMIN_EMAILS=contact@walztravels.com
ADMIN_PASSWORD_HASH=                 # bcrypt hash; or use ADMIN_PASSWORD for dev only
ADMIN_PASSWORD=                      # plaintext only for local dev — set HASH in production

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=change-me-to-a-random-secret

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Flutterwave ───────────────────────────────────────────────────────────────
FLW_SECRET_KEY=FLWSECK_LIVE-...
FLW_PUBLIC_KEY=FLWPUBK_LIVE-...
FLW_WEBHOOK_SECRET=...

# ── AXA Partners Travel Insurance ────────────────────────────────────────────
# Real values come from your AXA Partners referent (Auth0 client credentials).
# When set, AXA is used as the primary insurance provider.
# Battleface remains active as a fallback when AXA is not configured.
AXA_CLIENT_ID=
AXA_CLIENT_SECRET=
# Optional — defaults shown below (only set if your referent gives you different URLs)
AXA_API_BASE=https://apis.axa-assistance.com
AXA_AUTH_URL=https://auth.api.axapartners.com/oauth/token

# ── Battleface (Travel Insurance — fallback) ──────────────────────────────────
# Used when AXA_CLIENT_ID / AXA_CLIENT_SECRET are not set.
BATTLEFACE_API_URL=
BATTLEFACE_BEARER_TOKEN=

# ── Paga Collect ──────────────────────────────────────────────────────────────
# SECURITY: Rotate these before use if they were ever shared in a chat / log
PAGA_PUBLIC_KEY=
PAGA_SECRET_KEY=
PAGA_HMAC_KEY=
# Optional — defaults to https://collect.paga.com (server-to-server Collect API)
PAGA_COLLECT_URL=https://collect.paga.com
# Optional — defaults to https://checkout.paga.com (browser-hosted checkout page)
PAGA_CHECKOUT_URL=https://checkout.paga.com

# ── Resend (Email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@walztravels.com

# ── Redis (Optional — app degrades gracefully if not set) ─────────────────────
REDIS_URL=redis://default:[password]@[host]:6379

# ── Sabre (Flights) ───────────────────────────────────────────────────────────
SABRE_CLIENT_ID=
SABRE_CLIENT_SECRET=
SABRE_API_URL=https://api.cert.sabre.com

# ── Hotelbeds (Hotels & Activities) ──────────────────────────────────────────
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
HOTELBEDS_API_URL=https://api.test.hotelbeds.com

# ── Google (Analytics / OAuth) ───────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
